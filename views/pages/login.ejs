<%- include('partials/header') %> <!-- Inkluderer header-partialen (uten escaping) -->

<h1><%= title %></h1> <!-- Viser sidetittel trygt -->

<% if (typeof message !== 'undefined' && message) { %> <!-- Hvis serveren har sendt en melding -->
  <div class="notice"><%= message %></div> <!-- Viser meldingen i en meldingsboks -->
<% } %> <!-- Slutt på melding-sjekk -->

<section class="card"> <!-- Kort med skjema for å legge til sang -->
  <h2>side 2</h2> <!-- Seksjonstittel -->
</section> <!-- Slutt på skjema-kort -->

<section class="card"> <!-- Kort med skjema for å legge til sang -->
  <h2>Create Account</h2> <!-- Seksjonstittel -->
   <form action="/users" method="POST" class="form"> <!-- Skjema som sender POST til /users -->
     <!-- Lenke som peker til Express-ruten "/login" (ikke direkte til test.ejs-filen) -->
    
    <label for="Username">Username</label> <!-- Etikett for Username -->
    <input id="Username" name="Username" type="text" required /> <!-- Tekstfelt for Username (påkrevd) -->
    
    <label for="password">Password</label> <!-- Etikett for password -->
    <input id="password" name="password" type="password" required /> <!-- Passordfelt (påkrevd) -->

    <label for="email">Email</label> <!-- Etikett for email -->
    <input id="email" name="email" type="email" required /> <!-- Email-input (påkrevd) -->

    <button type="submit">Confirm</button> <!-- Sendeknapp for skjemaet -->
  </form> <!-- Slutt på skjema -->
</section> <!-- Slutt på skjema-kort -->

<section class="card"> <!-- Kort som viser registrerte sanger -->
  <h2>Registrerte brukere</h2> <!-- Seksjonstittel -->
  <ul> <!-- Starter liste over sanger -->
    <% if (users.length === 0) { %> <!-- Sjekker om listen er tom -->
      <li>(Ingen sanger enda)</li> <!-- Viser tekst når det ikke finnes sanger -->
    <% } %> <!-- Slutt på tom-sjekk -->
    <% for (const user of users) { %> <!-- Løkker gjennom alle sanger -->
      <li> <!-- Starter listeelement -->
        <strong><%= user.username %></strong> av <em><%= user.email %></em> <!-- Viser tittel, artist og nasjonalitet trygt -->
        <span class="muted">— <%= user.created_at %></span> <!-- Viser dato trygt -->
      </li> <!-- Slutt på listeelement -->
    <% } %> <!-- Slutt på løkke -->
  </ul> <!-- Slutt på liste -->
</section> <!-- Slutt på liste-kort -->

<%- include('partials/footer') %> <!-- Inkluderer footer-partialen (uten escaping) -->